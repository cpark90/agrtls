<launch>
  <!-- Anchor layout to use.  Pass a different file to switch deployments:
         roslaunch harvest_recorder bringup.launch \
           anchors:=$(rospack find uwb_positioning)/config/anchors/lab.yaml
  -->
  <arg name="anchors"
       default="$(find uwb_positioning)/config/anchors/default.yaml" />

  <!-- UWB positioning — forward anchor selection -->
  <include file="$(find uwb_positioning)/launch/uwb_positioning.launch">
    <arg name="anchors" value="$(arg anchors)" />
  </include>

  <!-- Weight scale reader -->
  <include file="$(find scale_reader)/launch/scale_reader.launch" />

  <!-- Time-aligner + recorder -->
  <rosparam command="load" file="$(find harvest_recorder)/config/params.yaml" />
  <node name="recorder" pkg="harvest_recorder" type="recorder_node" output="screen" />
</launch>
