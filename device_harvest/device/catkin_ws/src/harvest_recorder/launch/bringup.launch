<launch>
  <!-- UWB positioning -->
  <include file="$(find uwb_positioning)/launch/uwb_positioning.launch" />

  <!-- Weight scale reader -->
  <include file="$(find scale_reader)/launch/scale_reader.launch" />

  <!-- Time-aligner + recorder -->
  <rosparam command="load" file="$(find harvest_recorder)/config/params.yaml" />
  <node name="recorder" pkg="harvest_recorder" type="recorder_node" output="screen" />
</launch>
